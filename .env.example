# Server-only HubSpot private app token. Never expose this as NEXT_PUBLIC_*.
HUBSPOT_PRIVATE_APP_TOKEN=
HUBSPOT_PORTAL_ID=145742477
HUBSPOT_UI_DOMAIN=app-eu1.hubspot.com
HUBSPOT_TIMEZONE=Asia/Riyadh

# Dashboard defaults
DEFAULT_SDR_OWNER_ID=31644369
NEXT_PUBLIC_DEFAULT_START_DATE=2026-07-01

# Built-in Basic Auth. Configure both values in production.
DASHBOARD_USERNAME=
DASHBOARD_PASSWORD=
DISABLE_AUTH=false

# Google Calendar OAuth for Marita Workspace. Server-only; never commit live values.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://sdr.dashboardtalentera.tech/api/google/callback
GOOGLE_TOKEN_ENCRYPTION_KEY=
MARITA_GOOGLE_EMAIL=
GOOGLE_TOKEN_STORE_PATH=/app/data/google-calendar.json

# Safe synthetic data for local UI development and CI.
DEMO_MODE=true
